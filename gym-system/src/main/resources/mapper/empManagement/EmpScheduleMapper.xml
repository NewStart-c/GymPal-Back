<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gym.empManagement.mapper.EmpScheduleMapper">
    
    <resultMap type="EmpSchedule" id="EmpScheduleResult">
        <result property="scheduleId"    column="schedule_id"    />
        <result property="userId"    column="user_id"    />
        <result property="scheduleDate"    column="schedule_date"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="scheduleType"    column="schedule_type"    />
        <result property="workContent"    column="work_content"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectEmpScheduleVo">
        select schedule_id, user_id, schedule_date, start_time, end_time, schedule_type, work_content, status, del_flag, create_by, create_time, update_by, update_time, remark from emp_schedule
    </sql>

    <select id="selectEmpScheduleList" parameterType="EmpSchedule" resultMap="EmpScheduleResult">
        <include refid="selectEmpScheduleVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="scheduleDate != null "> and schedule_date = #{scheduleDate}</if>
            <if test="startTime != null">
                AND schedule_date >= #{startTime}
            </if>
            <if test="endTime != null">
                AND schedule_date &lt;= #{endTime}
            </if>
            <if test="scheduleType != null  and scheduleType != ''"> and schedule_type = #{scheduleType}</if>
            <if test="workContent != null  and workContent != ''"> and work_content = #{workContent}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectEmpScheduleByScheduleId" parameterType="Long" resultMap="EmpScheduleResult">
        <include refid="selectEmpScheduleVo"/>
        where schedule_id = #{scheduleId}
    </select>

    <insert id="insertEmpSchedule" parameterType="EmpSchedule" useGeneratedKeys="true" keyProperty="scheduleId">
        insert into emp_schedule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="scheduleDate != null">schedule_date,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="scheduleType != null and scheduleType != ''">schedule_type,</if>
            <if test="workContent != null">work_content,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="scheduleDate != null">#{scheduleDate},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="scheduleType != null and scheduleType != ''">#{scheduleType},</if>
            <if test="workContent != null">#{workContent},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateEmpSchedule" parameterType="EmpSchedule">
        update emp_schedule
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="scheduleDate != null">schedule_date = #{scheduleDate},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="scheduleType != null and scheduleType != ''">schedule_type = #{scheduleType},</if>
            <if test="workContent != null">work_content = #{workContent},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where schedule_id = #{scheduleId}
    </update>

    <delete id="deleteEmpScheduleByScheduleId" parameterType="Long">
        delete from emp_schedule where schedule_id = #{scheduleId}
    </delete>

    <delete id="deleteEmpScheduleByScheduleIds" parameterType="String">
        delete from emp_schedule where schedule_id in 
        <foreach item="scheduleId" collection="array" open="(" separator="," close=")">
            #{scheduleId}
        </foreach>
    </delete>
</mapper>