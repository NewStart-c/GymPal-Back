<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gym.courseManagement.mapper.CourseReservationMapper">
    
    <resultMap type="CourseReservation" id="CourseReservationResult">
        <result property="reservationId"    column="reservation_id"    />
        <result property="memberId"    column="member_id"    />
        <result property="courseId"    column="course_id"    />
        <result property="trainerId"    column="trainer_id"    />
        <result property="reservationTime"    column="reservation_time"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="courseName"    column="course_name"    />
    </resultMap>

    <sql id="selectCourseReservationVo">
        select reservation_id, member_id, course_id, trainer_id, reservation_time, status, create_by, create_time, update_by, update_time, remark from course_reservation
    </sql>

